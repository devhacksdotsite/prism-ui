{
  "name": "prism-ui",
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "description": "A vibrant pastel design system and component library built with Vue 3, PrimeVue 4, and Tailwind CSS v4",
  "author": "Jesse Salinas",
  "repository": {
    "type": "git",
    "url": "https://github.com/devhacksdotsite/prism-ui"
  },
  "keywords": ["vue", "vue3", "primevue", "tailwind", "component-library", "design-system", "pastel", "ui"],
  "main": "./dist/prism-ui.js",
  "module": "./dist/prism-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/prism-ui.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/prism-ui.css",
    "./tokens.css": "./src/theme/tokens.css"
  },
  "files": [
    "dist",
    "src/theme/tokens.css"
  ],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "primevue": "^4.0.0"
  },
  "devDependencies": {
    "vue": "^3.5.32",
    "primevue": "^4.5.5",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "storybook": "^10.3.6",
    "@storybook/vue3-vite": "^10.3.6",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "vitest": "^4.1.5",
    "playwright": "^1.59.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  }
}
